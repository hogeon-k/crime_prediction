# Normalize text files in the repository and keep source/data files as LF.
* text=auto eol=lf

# Python projects are easiest to review and test cross-platform with LF.
*.py    text eol=lf
*.pyi   text eol=lf
*.csv   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf

# Windows scripts should remain CRLF when they are added later.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary/model artifacts must not be line-ending normalized.
*.pkl   binary
*.xlsx  binary
*.xls   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
